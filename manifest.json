{
  "manifest_version": 3,
  "name": "Translate URL Cleaner",
  "version": "1.0",
  "description": "Removes &tl=xx from Google Translate URLs and copies the clean link",
  "permissions": ["activeTab", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}